# The Dispatch configuration. Copy to .env and fill in values.
# Generate bearer tokens with: openssl rand -hex 32

# Local HTTP bind port (Caddy reverse-proxies to this)
PORT=8787

# Bearer used by the Claude Code Routines custom connector. Paste the same
# value into claude.ai → Settings → Connectors → Add custom connector.
MCP_BEARER_TOKEN=replace-with-openssl-rand-hex-32

# Free-form label for the second MCP client (e.g. "cli", "local-cc").
# Shows up in server logs so you can tell routine vs. client calls apart.
MCP_CLIENT_NAME=cli

# Bearer for that second client (e.g. your local Claude Code instance).
# Generate independently from MCP_BEARER_TOKEN so you can rotate one without
# touching the other.
MCP_CLIENT_TOKEN=replace-with-openssl-rand-hex-32

# Expected Host header on /mcp requests (DNS-rebinding defense per MCP spec).
MCP_EXPECTED_HOST=dispatch.platinumj.xyz

# Dashboard basic-auth credentials.
DASHBOARD_USER=editor
DASHBOARD_PASS=replace-me

# Storage paths. Relative paths resolve from the process CWD.
DB_PATH=./reports.db
ARCHIVE_DIR=./archive

# Used to build the `url` field in save_report responses.
PUBLIC_BASE_URL=https://dispatch.platinumj.xyz
